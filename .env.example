BOT_TOKEN=

# ID группы поддержки (отрицательное число).
# Получить: добавить бота в группу → написать сообщение →
# открыть https://api.telegram.org/bot<TOKEN>/getUpdates → найти chat.id
SUPPORT_CHAT_ID=

# Оставить пустым для запуска в режиме polling (без вебхука)
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_LISTEN_ADDR=:8080
WEBHOOK_SECRET_TOKEN=

# Для локальной разработки. В продакшне переопределяется docker-compose.yml
DATABASE_URL=postgres://yozatune:secret@localhost:5432/yozatune?sslmode=disable
